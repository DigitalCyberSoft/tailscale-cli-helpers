#!/usr/bin/env bash
#
# tscp - Tailscale SCP helper
# SCP with Tailscale hostname resolution
#

# Detect shell and set compatibility options
if [ -n "$ZSH_VERSION" ]; then
    emulate -L bash
    setopt BASH_REMATCH
    setopt KSH_ARRAYS
fi

# Enable safety features
set -o pipefail
IFS=$' \t\n'

# Version
TSCP_VERSION="0.2.1"

# Check dependencies
if ! command -v scp >/dev/null 2>&1; then
    echo "Error: scp is required but not installed" >&2
    exit 1
fi

# Get the directory where this script is located
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Source common utilities
if [[ -f "$SCRIPT_DIR/../lib/common.sh" ]]; then
    source "$SCRIPT_DIR/../lib/common.sh"
elif [[ -f "/usr/share/tailscale-cli-helpers/lib/common.sh" ]]; then
    source "/usr/share/tailscale-cli-helpers/lib/common.sh"
fi

# Source the shared resolver library
if [[ -f "$SCRIPT_DIR/../lib/tailscale-resolver.sh" ]]; then
    source "$SCRIPT_DIR/../lib/tailscale-resolver.sh"
elif [[ -f "/usr/share/tailscale-cli-helpers/lib/tailscale-resolver.sh" ]]; then
    source "/usr/share/tailscale-cli-helpers/lib/tailscale-resolver.sh"
else
    echo "Error: Cannot find tailscale-resolver.sh library" >&2
    exit 1
fi

# Show help
show_tscp_help() {
    echo "tscp - SCP with Tailscale hostname resolution v$TAILSCALE_CLI_HELPERS_VERSION"
    echo ""
    echo "Usage:"
    echo "  tscp [scp_options] source destination"
    echo ""
    echo "Options:"
    echo "  -h, --help       Show this help message"
    echo "  -V, --version    Show version information"
    echo ""
    echo "SCP file transfer with automatic Tailscale hostname resolution."
    echo "Resolves hostnames in remote file specifications (host:path)."
}

# Main function
main() {
    # Handle version and help early
    for arg in "$@"; do
        case "$arg" in
            --version|-V)
                echo "tscp $TAILSCALE_CLI_HELPERS_VERSION"
                exit 0
                ;;
            --help|-h)
                show_tscp_help
                exit 0
                ;;
        esac
    done
    
    if [[ $# -eq 0 ]]; then
        show_tscp_help
        exit 1
    fi
    
    local scp_opts=()
    local file_args=()
    local i=1

    # Separate scp options from source/target arguments
    while [[ $i -le $# ]]; do
        local arg="${!i}"

        if [[ "$arg" == "-"* ]]; then
            scp_opts+=("$arg")
            ((i++))
            # Options that take a value argument
            case "$arg" in
                -c|-D|-F|-i|-J|-l|-o|-P|-S|-X)
                    if [[ $i -le $# ]]; then
                        scp_opts+=("${!i}")
                        ((i++))
                    fi
                    ;;
            esac
        else
            file_args+=("$arg")
            ((i++))
        fi
    done

    # Resolve hostnames in source/target arguments
    local resolved_file_args=()

    for arg in "${file_args[@]}"; do
        if [[ "$arg" == *":"* ]]; then
            # This looks like a remote host:path spec
            local host_part="${arg%%:*}"
            local path_part="${arg#*:}"

            # Resolve hostname interactively, showing which arg we're resolving
            local resolved_host
            resolved_host=$(resolve_host_interactive "$host_part" "$arg")
            if [[ $? -eq 0 ]]; then
                resolved_file_args+=("${resolved_host}:${path_part}")
            else
                # Keep original if not resolvable
                resolved_file_args+=("$arg")
            fi
        else
            resolved_file_args+=("$arg")
        fi
    done

    # Execute scp with options first, then resolved source/target
    exec scp "${scp_opts[@]}" "${resolved_file_args[@]}"
}

# Run main function
main "$@"